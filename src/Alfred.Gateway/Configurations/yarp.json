{
  "ReverseProxy": {
    "Routes": {

      // ─────────────────────────── IDENTITY ──────────────────────────────────
      "identity-swagger-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/api/identity/swagger/{**remainder}" },
        "Transforms": [ { "PathPattern": "/swagger/{**remainder}" } ]
      },
      "identity-auth-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/identity/auth/{**remainder}" },
        "Transforms": [
          { "X-Forwarded": "Set" },
          { "RequestHeader": "X-Forwarded-Proto", "Set": "https" }
        ],
        "Order": 1
      },
      "identity-connect-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/connect/{**remainder}" },
        "Transforms": [
          { "X-Forwarded": "Set" },
          { "RequestHeader": "X-Forwarded-Proto", "Set": "https" }
        ],
        "Order": 1
      },
      "identity-wellknown-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/.well-known/{**remainder}" },
        "Order": 1
      },
      "identity-applications-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/applications/{**remainder}" },
        "Order": 1
      },
      "identity-roles-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/roles/{**remainder}" },
        "Order": 1
      },
      "identity-permissions-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/permissions/{**remainder}" },
        "Order": 1
      },
      "identity-users-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/users/{**remainder}" },
        "Order": 1
      },
      "identity-catchall-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/identity/{**remainder}" },
        "Order": 10
      },

      // ─────────────────────────── CORE ──────────────────────────────────────
      "core-swagger-route": {
        "ClusterId": "core-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/api/core/swagger/{**remainder}" },
        "Transforms": [ { "PathPattern": "/swagger/{**remainder}" } ]
      },
      "core-route": {
        "ClusterId": "core-cluster",
        "AuthorizationPolicy": "Authenticated",
        "RateLimiterPolicy": "fixed-window",
        "Match": { "Path": "/api/{**remainder}" },
        "Order": 100
      },

      // ─────────────────────────── NOTIFICATION ──────────────────────────────
      "notification-swagger-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/api/notification/swagger/{**remainder}" },
        "Transforms": [ { "PathPattern": "/{**remainder}" } ]
      },
      "notification-templates-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": { "Path": "/templates/{**remainder}" },
        "Order": 1
      },

      // ─────────────────────────── HEALTH ────────────────────────────────────
      "health-check-identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/health/identity" },
        "Transforms": [ { "PathPattern": "/health" } ]
      },
      "health-check-core-route": {
        "ClusterId": "core-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/health/core" },
        "Transforms": [ { "PathPattern": "/health" } ]
      },
      "health-check-notification-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "AllowAnonymous",
        "Match": { "Path": "/health/notification" },
        "Transforms": [ { "PathPattern": "/health" } ]
      }
    },

    "Clusters": {
      // Addresses are injected at startup from env vars:
      //   IDENTITY_SERVICE_URL / IDENTITY_SERVICE_MTLS_URL
      //   CORE_SERVICE_URL     / CORE_SERVICE_MTLS_URL
      //   NOTIFICATION_SERVICE_URL
      "identity-cluster": {
        "Destinations": { "destination1": {} },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "core-cluster": {
        "Destinations": { "destination1": {} },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "notification-cluster": {
        "Destinations": { "destination1": {} },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      }
    }
  }
}