# -----------------------------------------------------------------------------
# Alfred Gateway (API Gateway / Reverse Proxy) - Environment Variables
# Copy this file to .env and fill in your values.
# -----------------------------------------------------------------------------

# -- [Optional] Application ----------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
APP_HOSTNAME=localhost
APP_PORT=8000

# -- [Required] Authentication -------------------------------------------------
# Base URL used by the gateway to fetch /.well-known/jwks.json.
AUTH_AUTHORITY=https://gateway.test
# Must match Jwt__Issuer on the Identity service. Mismatch = 401 on all API calls.
AUTH_VALID_ISSUER=https://gateway.test
AUTH_REQUIRE_HTTPS_METADATA=false

# -- [Required] CORS -----------------------------------------------------------
# Comma-separated list of allowed origins (all frontends)
CORS_ALLOWED_ORIGINS=https://sso.test,https://core.test

# -- [Optional] Rate Limiting --------------------------------------------------
# Defaults to false in Development. Set true to test throttling locally.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MINUTES=1
RATE_LIMIT_PERMIT_LIMIT=100
RATE_LIMIT_QUEUE_LIMIT=2

# -- [Required] Dynamic Proxy Definitions -------------------------------------
# Routing is env-driven. Each DYNAMIC_PROXY__<NAME> entry is a JSON object.
# kind=identity => identity-specific routes: /identity/v1/auth, /connect, /.well-known, /identity/v1/mgmt/users...
DYNAMIC_PROXY__IDENTITY={"kind":"identity","slug":"identity","address":"http://localhost:8100"}
# kind=api => API + swagger + health routes. Declare only services you want gateway to route/probe.
DYNAMIC_PROXY__CORE={"kind":"api","slug":"core","address":"http://localhost:8200","order":20}
# DYNAMIC_PROXY__NOTIFICATION={"kind":"api","slug":"notification","address":"http://localhost:8300","apiPath":"/templates/{**remainder}","swaggerPath":"/api/notification/swagger/{**remainder}","healthPath":"/health/notification","swaggerTransformPath":"/{**remainder}","order":30}

# -- [Optional] Legacy service URL fallback -----------------------------------
# Kept for compatibility when DYNAMIC_PROXY__* is not configured.
# IDENTITY_SERVICE_URL=http://localhost:8100
# CORE_SERVICE_URL=http://localhost:8200
# NOTIFICATION_SERVICE_URL=http://localhost:8300

# -- [Optional] Health Check ---------------------------------------------------
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=10

# -- [Optional] Redis - session/cache sharing ---------------------------------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# -- [Optional] mTLS - only when running behind a service mesh -----------------
# MTLS_ENABLED=false
# MTLS_CLIENT_CERT_PATH=
# MTLS_CLIENT_CERT_PASSWORD=
# MTLS_CA_CERT_PATH=
# MTLS_SKIP_SERVER_CERT_VALIDATION=false
# When MTLS_ENABLED=true with legacy fallback, traffic can route to HTTPS ports.
# IDENTITY_SERVICE_MTLS_URL=https://localhost:8101
# CORE_SERVICE_MTLS_URL=https://localhost:8201
